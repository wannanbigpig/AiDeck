{
  "name": "aideck",
  "version": "1.0.1",
  "description": "AiDeck desktop shell",
  "author": "AiDeck <support@aideck.com>",
  "homepage": "https://github.com/wannanbigpig/AiDeck",
  "main": "dist-electron/main/main.cjs",
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "build": "vite build --config vite.config.mjs && node ./scripts/postbuild.cjs",
    "start": "electron .",
    "build:mac": "npm run build && electron-builder --mac dmg",
    "build:win": "npm run build && electron-builder --win nsis",
    "build:linux": "npm run build && electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.aideck.desktop",
    "productName": "AiDeck",
    "electronVersion": "34.0.0",
    "npmRebuild": false,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist-packages"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "maintainer": "AiDeck <support@aideck.com>",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development"
    }
  },
  "dependencies": {
    "@aideck/app-shell": "file:../../packages/app-shell",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "34.0.0",
    "electron-builder": "24.13.3",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.1"
  }
}
